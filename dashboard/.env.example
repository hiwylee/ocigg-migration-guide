# =============================================================
# Migration Dashboard — 환경변수 템플릿
# 실제 값은 .env 파일에 작성 (git 포함 금지)
# 변수명은 scripts/config/env.sh 와 1:1 매핑
# =============================================================

# ─────────────────────────────────────────────
# 소스 DB (AWS RDS Oracle SE)
# ─────────────────────────────────────────────
SRC_DB_HOST=
SRC_DB_PORT=1521
SRC_DB_SID=
SRC_DB_SERVICE=
SRC_DBA_USER=admin
SRC_DBA_PASS=
SRC_GG_USER=GGADMIN
SRC_GG_PASS=
SRC_MIG_USER=MIGRATION_USER
SRC_MIG_PASS=

# ─────────────────────────────────────────────
# 타겟 DB (OCI DBCS Oracle SE)
# ─────────────────────────────────────────────
TGT_DB_HOST=
TGT_DB_PORT=1521
TGT_DB_SID=
TGT_DB_SERVICE=
TGT_DBA_USER=SYS
TGT_DBA_PASS=
TGT_GG_USER=GGADMIN
TGT_GG_PASS=
TGT_MIG_USER=MIGRATION_USER
TGT_MIG_PASS=

# ─────────────────────────────────────────────
# OCI GoldenGate Admin Server
# ─────────────────────────────────────────────
GG_ADMIN_URL=
GG_ADMIN_USER=oggadmin
GG_ADMIN_PASS=
GG_DEPLOYMENT_NAME=
GG_EXTRACT_NAME=EXT1
GG_PUMP_NAME=PUMP1
GG_REPLICAT_NAME=REP1
# TLS CA 번들 경로 (verify=False 금지)
GG_CA_BUNDLE=/app/certs/ca-bundle.crt

# ─────────────────────────────────────────────
# OCI Object Storage
# ─────────────────────────────────────────────
OCI_NAMESPACE=
OCI_BUCKET=
OCI_REGION=ap-tokyo-1

# ─────────────────────────────────────────────
# 마이그레이션 스키마 (쉼표 구분)
# ─────────────────────────────────────────────
MIGRATION_SCHEMAS=

# ─────────────────────────────────────────────
# JWT — 반드시 랜덤 값으로 변경
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─────────────────────────────────────────────
# 관리자 계정 (초기 기동 시 자동 생성)
# ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ─────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
LAG_WARNING_SECONDS=15
LAG_CRITICAL_SECONDS=30
DB_PATH=/app/db/dashboard.db
